# Plantilla de variables de entorno.
# Copiar a `.env` y rellenar.
# cp .env.example .env

# Proveedor de LLM de razonamiento: "anthropic" (por defecto) o "groq".
LLM_PROVIDER=anthropic

# Claude API (proveedor por defecto) 
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

#  Groq (alternativa open para el demo en vivo) 
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

#  RAG / embeddings (corren en local; sin API)
EMBEDDING_MODEL=intfloat/multilingual-e5-large
CHROMA_DIR=data/chroma
RETRIEVAL_TOP_K=5